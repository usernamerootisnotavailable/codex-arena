ccodex(){
	docker run --rm -it \
		 -u 1000:1000 \
		 -v "$(pwd):$(pwd)" \
		 -v "$HOME/.codex:/home/ubuntu/.codex" \
		 -w "$(pwd)" \
		 -e OPENAI_API_KEY="$OPENAI_API_KEY" \
		 -e TERM=xterm-256color \
		 -e COLORTERM=truecolor \
		 -e LANG="${LANG:-C.UTF-8}" \
		 -e LC_ALL="${LC_ALL:-C.UTF-8}" \
		 codex-arena:testing codex --sandbox danger-full-access -a untrusted "$@"
}
